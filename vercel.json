{
  "version": 2,
  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/admin$", "dest": "/admin.html" },
    { "src": "^/player$", "dest": "/player.html" },
    { "src": "^/players$", "dest": "/players.html" },
    { "src": "^/league$", "dest": "/league.html" },
    { "src": "^/team/([^/]+)$", "dest": "/team.html" }
  ]
}